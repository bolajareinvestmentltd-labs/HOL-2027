# HOL-2027 Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database"
DIRECT_URL="postgresql://user:password@host/database"

# Vercel / Next.js
NEXT_PUBLIC_SITE_URL="https://hol-2027.vercel.app"
NEXT_PUBLIC_API_BASE="https://hol-2027.vercel.app/api"
NODE_ENV="production"

# Authentication (Choose Clerk OR NextAuth - configure one)
# Clerk Setup
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# OR NextAuth.js Setup (uncomment if using NextAuth)
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="https://hol-2027.vercel.app"

# Email Service (SendGrid or Postmark)
SENDGRID_API_KEY=""
# OR Postmark Setup
# POSTMARK_API_KEY=""

# SMS (Optional - Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Monitoring & Error Tracking
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENABLED="true"

# Analytics
NEXT_PUBLIC_GA_ID=""

# File Storage (Cloudflare R2 or S3)
# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_CDN_URL=""

# OR Amazon S3
# AWS_S3_ACCESS_KEY_ID=""
# AWS_S3_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET_NAME=""
# AWS_S3_REGION=""

# Search (Optional - Algolia)
# NEXT_PUBLIC_ALGOLIA_APP_ID=""
# ALGOLIA_ADMIN_API_KEY=""
# ALGOLIA_SEARCH_API_KEY=""

# Admin / Moderation Settings
ADMIN_TOKEN=""
ADMIN_EMAIL="admin@hol2027.ng"
SUPPORT_EMAIL="support@hol2027.ng"
MEDIA_EMAIL="media@hol2027.ng"

# Campaign Settings
CAMPAIGN_NAME="HOL 2027"
CAMPAIGN_TAGLINE="Legacy of Service, Future for Kwara"
CAMPAIGN_LEAD_NAME="Alh. Hakeem Oladimeji Lawal"

# Feature Flags
ENABLE_DONATIONS="false"  # Set to true only after legal review
ENABLE_Q_AND_A="true"
ENABLE_SUGGESTIONS="true"
ENABLE_GALLERY="true"
ENABLE_NEWSROOM="true"

# Moderation
MODERATION_AUTO_FILTER_ENABLED="true"
MODERATION_REQUIRE_APPROVAL="false"
MODERATION_TIMEOUT_HOURS="24"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"