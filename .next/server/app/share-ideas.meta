{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/share-ideas/layout,_N_T_/share-ideas/page,_N_T_/share-ideas"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/share-ideas/__PAGE__",
    "/share-ideas",
    "/_index",
    "/_head"
  ]
}